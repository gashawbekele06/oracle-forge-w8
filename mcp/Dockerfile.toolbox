FROM debian:bookworm-slim

ARG TOOLBOX_VERSION=0.30.0

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL -o /usr/local/bin/toolbox "https://storage.googleapis.com/genai-toolbox/v${TOOLBOX_VERSION}/linux/amd64/toolbox" \
    && chmod +x /usr/local/bin/toolbox

EXPOSE 5000

ENTRYPOINT ["toolbox"]
